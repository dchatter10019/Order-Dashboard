# Server Configuration
PORT=3001
NODE_ENV=development

# Order dates: IANA timezone for calendar-day boundaries (used when client does not send timeZone, e.g. auto-refresh)
BEVVI_ORDER_TIMEZONE=America/New_York

# API Configuration
BEVVI_API_BASE_URL=https://api.getbevvi.com
BEVVI_API_TIMEOUT=30000

# Slack (optional) — time-based alerts for pending & accepted orders when orders are loaded / auto-refresh
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Security
SESSION_SECRET=your-session-secret-here
# Allowed browser origin for API when frontend is on a different host (e.g. deployed SPA).
# Local dev origins are built-in; add your production frontend URL here if needed.
CORS_ORIGIN=http://localhost:3000

# If the React app is served separately from server.js (e.g. static hosting), set the full API origin:
# VITE_API_BASE_URL=http://localhost:3001

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Web Search (optional, for UPC enrichment)
SERPAPI_API_KEY=your-serpapi-api-key-here

# Stripe (optional, for Manual Order Add payment links after order creation)
# Use your Stripe secret key (sk_test_... or sk_live_...). Creates shareable Payment Links for email.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
# Enable Stripe Tax in the Stripe Dashboard for automatic tax on manual order checkout links.
# Optional redirect URLs after the customer pays or cancels (use {CHECKOUT_SESSION_ID} in success URL)
# STRIPE_PAYMENT_SUCCESS_URL=https://getbevvi.com/?payment=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_PAYMENT_CANCEL_URL=https://getbevvi.com/?payment=cancelled

# Google Maps (optional, for Manual Order Add address autocomplete/geocoding)
# Enable Places API (New) and Geocoding API on your Google Cloud project.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Asana Configuration
# Get your Asana Personal Access Token from: https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=your-asana-personal-access-token-here
# Get your Workspace GID from Asana API or workspace URL
ASANA_WORKSPACE_GID=your-asana-workspace-gid-here
# Optional: Project GID to add tasks to a specific project
ASANA_PROJECT_GID=your-asana-project-gid-here

# Facebook/Meta API Configuration
# Format: App ID / Page ID / Post ID : Access Token
FACEBOOK_API_IDENTIFIER=2/568120696269174/1212643658293191:5832a006a2cbb8f392dc4fa5b4707e61
